<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.springbootmybatisdemo.mapper.StuInfoMapper">


    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.example.springbootmybatisdemo.entity.StuInfo">
        <id property="stuId" column="stu_id"/>
        <result property="stuName" column="stu_name"/>
        <result property="stuNo" column="stu_no"/>
        <result property="className" column="class_name"/>
    </resultMap>


    <!-- 对应接口中的 selectById2 方法 -->
    <select id="selectById2" resultType="com.example.springbootmybatisdemo.entity.StuInfo">
<!--    <select id="selectById2" resultMap="BaseResultMap">-->
        SELECT *
        FROM stu_info
        WHERE stu_id = #{stuId}
    </select>


    <!-- 批量删除 -->
    <delete id="deleteBatch">
        DELETE FROM stu_info
        WHERE stu_id IN
        <!-- collection: 对应接口中 @Param 的值 -->
        <!-- item: 集合中每个元素的别名 -->
        <!-- separator: 分隔符 -->
        <!-- open: 开始符号 -->
        <!-- close: 结束符号 -->
        <foreach collection="ids" item="id" separator="," open="(" close=")">
            #{id}
        </foreach>
    </delete>



    <!--  下面是"动态多表映射SQL"相关的内容   -->

    <!-- ==========================================
     1. 复杂结果映射：学生 + 成绩列表
     注意：javaType="ArrayList" ofType="ScoreRecord"
     ========================================== -->
    <resultMap id="StudentWithScoreResultMap" type="com.example.springbootmybatisdemo.entity.StuInfo2">
        <!-- 基础列映射 -->
        <id property="stuId" column="stu_id"/>
        <result property="stuName" column="stu_name"/>
        <result property="stuNo" column="stu_no"/>
        <result property="className" column="class_name"/>

        <!-- 集合映射：映射成绩列表 -->
        <!-- property: 对应 StuInfo 类中的属性名 -->
        <!-- javaType: 集合类型 -->
        <!-- ofType: 集合中泛型的类型 (相当于泛型里的 Class) -->
        <collection property="scoreList"
                    javaType="ArrayList"
                    ofType="com.example.springbootmybatisdemo.entity.ScoreRecord"
                    resultMap="ScoreRecordMap"/>
    </resultMap>

    <!-- 单独定义 ScoreRecord 的映射，供上面复用 -->
    <resultMap id="ScoreRecordMap" type="com.example.springbootmybatisdemo.entity.ScoreRecord">
        <id property="id" column="score_id"/>
        <result property="subject" column="subject"/>
        <result property="score" column="score"/>
        <result property="examDate" column="exam_date"/>
    </resultMap>


    <!-- ==========================================
         2. SQL 片段：查询字段
         ========================================== -->
    <sql id="StudentBaseColumns">
        si.stu_id, si.stu_name, si.stu_no, si.class_name
    </sql>

    <sql id="ScoreBaseColumns">
        sr.id as score_id, sr.subject, sr.score, sr.exam_date
    </sql>


    <!-- ==========================================
         3. 动态多表查询接口
         ========================================== -->
    <select id="selectStudentWithScores" resultMap="StudentWithScoreResultMap">
        <!-- 注意：这里必须手动拼接字段，不能用 *，否则 MyBatis 无法区分哪个字段属于哪个表 -->
        SELECT
        <include refid="StudentBaseColumns"/>,
        <include refid="ScoreBaseColumns"/>
        FROM stu_info si
        LEFT JOIN score_record sr ON si.stu_no = sr.stu_no
        <!-- 动态 WHERE 条件 -->
        <where>
            <!-- 如果传入了 stuName，则模糊查询 -->
            <if test="condition.stuName != null and condition.stuName != ''">
                AND si.stu_name LIKE CONCAT('%', #{condition.stuName}, '%')
            </if>
            <!-- 如果传入了 subject，则查询特定科目 -->
            <if test="condition.scoreList != null and condition.scoreList.size() > 0">
                <!-- 假设我们取第一个元素的 subject 作为查询条件 -->
                AND sr.subject = #{condition.scoreList[0].subject}
            </if>
            <!-- 如果传入了 className，则查询特定班级 -->
            <if test="condition.className != null and condition.className != ''">
                AND si.class_name = #{condition.className}
            </if>
        </where>
        ORDER BY si.stu_no, sr.subject
    </select>

</mapper>
